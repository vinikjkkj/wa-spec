{
    "name": "@vinikjkkj/wa-proto",
    "version": "2.3000.1042640601-9dda465",
    "description": "WhatsApp Web protobuf message bindings — pbjs/pbts compiled from daily-extracted SDL.",
    "keywords": [
        "whatsapp",
        "whatsapp-web",
        "waproto",
        "wa-proto",
        "protobuf",
        "protobufjs",
        "pbjs",
        "wa-spec"
    ],
    "license": "MIT",
    "author": {
        "name": "vinikjkkj",
        "url": "https://github.com/vinikjkkj"
    },
    "homepage": "https://github.com/vinikjkkj/wa-spec/tree/main/packages/proto#readme",
    "bugs": {
        "url": "https://github.com/vinikjkkj/wa-spec/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vinikjkkj/wa-spec.git",
        "directory": "packages/proto"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/vinikjkkj"
        }
    ],
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "sideEffects": false,
    "files": [
        "dist/index.js",
        "dist/index.d.ts",
        "README.md"
    ],
    "scripts": {
        "apply": "node ./scripts/apply.cjs",
        "compile": "npm run compile:js && npm run compile:ts",
        "compile:js": "node -e \"require('node:fs').mkdirSync('dist', { recursive: true })\" && pbjs -t static-module --sparse -w commonjs -o ./dist/index.js ./WAProto.proto",
        "compile:ts": "pbts -o ./dist/index.d.ts ./dist/index.js",
        "build": "npm run apply && npm run compile"
    },
    "dependencies": {
        "long": "^5.3.2",
        "protobufjs": "^7.4.0"
    },
    "devDependencies": {
        "protobufjs-cli": "^1.1.3"
    },
    "engines": {
        "node": ">=20.9.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
